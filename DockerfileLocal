# Базовый образ для платформы Synapse
FROM synapse-base:latest

# Информация об авторе проекта
LABEL author="Твоё Имя"
LABEL maintainer="Твоё Имя"
LABEL description="Главный контейнер приложения Synapse"

# Настройка ветки сборки (по умолчанию используется local)
ARG SYNAPSE_BRANCH=local
ENV SYNAPSE_BRANCH=$SYNAPSE_BRANCH

# Копирование подготовленной файловой системы контейнера
COPY ./docker/run/fs/ /

# Загрузка исходного кода Synapse (применяется только для ветки local)
COPY ./ /git/synapse

# Этап 1: Предварительная настройка окружения
RUN bash /ins/pre_install.sh $SYNAPSE_BRANCH

# Этап 2: Установка ядра Synapse
ENV UV_HTTP_TIMEOUT=1000
ENV UV_INDEX_STRATEGY=unsafe-best-match
ENV UV_PRERELEASE=disallow
ENV UV_RETRIES=10
RUN --mount=type=cache,target=/root/.cache/uv \
    bash /ins/install_synapse.sh $SYNAPSE_BRANCH

# Этап 3: Установка дополнительных модулей и зависимостей
RUN bash /ins/install_additional.sh $SYNAPSE_BRANCH

# Этап 4: Инвалидация кэша сборки и финальная настройка ядра Synapse
ARG SYNAPSE_CACHE_DATE=none
RUN --mount=type=cache,target=/root/.cache/uv \
    echo "Сброс кэша сборки: $SYNAPSE_CACHE_DATE" && bash /ins/install_synapse2.sh $SYNAPSE_BRANCH

# Установка Playwright Chromium для браузерного агента
RUN /opt/venv-synapse/bin/python -m playwright install chromium

# Этап 5: Пост-установочные скрипты и очистка временных файлов
RUN bash /ins/post_install.sh $SYNAPSE_BRANCH

# Проброс необходимых портов:
# 22 - SSH-подключение
# 80 - Веб-интерфейс
# 9000-9009 - Внутренние микросервисы и API
EXPOSE 22 80 9000-9009

# Выдача прав на выполнение скриптам запуска платформы
RUN chmod +x /exe/initialize.sh /exe/run_synapse.sh /exe/run_searxng.sh /exe/run_tunnel_api.sh

# Инициализация среды и передача управления менеджеру процессов supervisord
CMD ["/exe/initialize.sh", "$SYNAPSE_BRANCH"]
